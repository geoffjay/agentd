<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.geoffjay.agentd-memory</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Applications/Agent.app/Contents/MacOS/agentd-memory</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/agentd-memory.log</string>

    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/agentd-memory.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_LOG</key>
        <string>info</string>
        <key>AGENTD_PORT</key>
        <string>7008</string>
        <key>AGENTD_MEMORY_EMBEDDING_PROVIDER</key>
        <string>openai</string>
        <key>AGENTD_MEMORY_EMBEDDING_MODEL</key>
        <string>all-minilm</string>
        <key>AGENTD_MEMORY_EMBEDDING_API_KEY</key>
        <string></string>
        <key>AGENTD_MEMORY_EMBEDDING_ENDPOINT</key>
        <string>http://localhost:11434/v1</string>
        <!--
        <key>AGENTD_MEMORY_LANCE_PATH</key>
        <string></string>
        <key>AGENTD_MEMORY_LANCE_TABLE</key>
        <string></string>
        -->
    </dict>

    <key>WorkingDirectory</key>
    <string>/usr/local</string>
</dict>
</plist>
